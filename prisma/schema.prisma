generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Log {
  id            Int      @id @default(autoincrement())
  actor         String
  action        String
  payload       Json
  previousHash  String?
  currentHash   String   @unique
  createdAt     DateTime @default(now())

  @@map("logs")
}